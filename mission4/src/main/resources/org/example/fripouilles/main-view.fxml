<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.fripouilles.controller.MainController"
           style="-fx-background-color: transparent;">

    <BorderPane fx:id="root" prefHeight="700" prefWidth="1200"
                style="-fx-background-color: white; -fx-background-radius: 10;">

        <!-- En-tête -->
        <top>
            <VBox style="-fx-background-color: #2196F3; -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <Label text="RAM Les Fripouilles - Gestion des Paies" style="-fx-text-fill: white;">
                        <font>
                            <Font name="System Bold" size="20"/>
                        </font>
                    </Label>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Déconnexion" onAction="#handleLogout"
                            style="-fx-background-color: white; -fx-text-fill: #2196F3;"/>
                </HBox>
            </VBox>
        </top>

        <!-- Contenu principal -->
        <center>
            <VBox spacing="15">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <!-- Barre de filtres -->
                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #f5f5f5; -fx-padding: 15; -fx-background-radius: 5;">
                    <Label text="Filtres:">
                        <font>
                            <Font name="System Bold" size="12"/>
                        </font>
                    </Label>
                    <Label text="Année:"/>
                    <ComboBox fx:id="anneeComboBox" onAction="#handleRefresh" prefWidth="100"/>
                    <Label text="Mois:"/>
                    <ComboBox fx:id="moisComboBox" onAction="#handleRefresh" prefWidth="100"/>
                    <TextField fx:id="searchField" promptText="Rechercher..." prefWidth="200"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="🔄 Actualiser" onAction="#handleRefresh"
                            style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                </HBox>

                <!-- Barre d'actions -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="+ Générer une paie" onAction="#handleGenererPaie"
                            style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;"
                            prefWidth="150"/>
                    <Button text="👁 Voir détails" onAction="#handleViewDetails"
                            style="-fx-background-color: #FF9800; -fx-text-fill: white;"
                            prefWidth="120"/>
                    <Button text="🗑 Supprimer" onAction="#handleDelete"
                            style="-fx-background-color: #f44336; -fx-text-fill: white;"
                            prefWidth="120"/>
                </HBox>

                <!-- Tableau des paies -->
                <TableView fx:id="paieTableView" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="contratColumn" text="Contrat / Enfant" prefWidth="200"/>
                        <TableColumn fx:id="assistantColumn" text="Assistante" prefWidth="150"/>
                        <TableColumn fx:id="parentColumn" text="Parent" prefWidth="150"/>
                        <TableColumn fx:id="periodeColumn" text="Période" prefWidth="100"/>
                        <TableColumn fx:id="heuresColumn" text="Total heures" prefWidth="100"/>
                        <TableColumn fx:id="salaireNetColumn" text="Salaire net" prefWidth="120"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <!-- Barre d'état -->
                <HBox spacing="10" style="-fx-background-color: #f5f5f5; -fx-padding: 10; -fx-background-radius: 5;">
                    <Label text="Double-cliquez sur une ligne pour voir les détails"
                           style="-fx-text-fill: #757575; -fx-font-style: italic;"/>
                </HBox>
            </VBox>
        </center>
    </BorderPane>

    <!-- Overlay grisé -->
    <StackPane fx:id="overlay"
               style="-fx-background-color: rgba(0,0,0,0.45); -fx-background-radius: 10;"
               visible="false" mouseTransparent="false"/>

</StackPane>