<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:mission5.ViewModels"
             mc:Ignorable="d" d:DesignWidth="950" d:DesignHeight="700"
             x:Class="mission5.Views.AteliersListView"
             x:DataType="vm:AteliersListViewModel">

    <Design.DataContext>
        <vm:AteliersListViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Spacing="20">

            <!-- En-tête -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Gestion des Ateliers"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#2d3748"/>
                    <TextBlock Text="Planification et suivi des ateliers d'éveil"
                               FontSize="14"
                               Foreground="#718096"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Command="{Binding CreateAtelierCommand}"
                        Background="#4299e1"
                        Foreground="White"
                        Padding="16,10"
                        CornerRadius="8"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="+" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Nouvel Atelier" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Barre d'actions -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="16"
                    BoxShadow="0 1 3 0 #1a000000">
                <Grid ColumnDefinitions="*,Auto">

                    <!-- Recherche -->
                    <TextBox Grid.Column="0"
                             Text="{Binding SearchText}"
                             Watermark="🔍  Rechercher un atelier..."
                             Padding="12,8"
                             FontSize="14"
                             CornerRadius="8"
                             BorderBrush="#e2e8f0"
                             BorderThickness="1"
                             MaxWidth="400"
                             HorizontalAlignment="Left"/>

                    <!-- Bouton Actualiser -->
                    <Button Grid.Column="1"
                            Command="{Binding RefreshCommand}"
                            Background="#edf2f7"
                            Foreground="#4a5568"
                            Padding="12,8"
                            CornerRadius="8"
                            BorderThickness="0"
                            Cursor="Hand">
                        <TextBlock Text="🔄 Actualiser" FontSize="14"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Message de chargement -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="40"
                    IsVisible="{Binding IsLoading}"
                    BoxShadow="0 1 3 0 #1a000000">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Chargement des ateliers..."
                               FontSize="14"
                               Foreground="#718096"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Liste des ateliers -->
            <ItemsControl ItemsSource="{Binding Ateliers}"
                          IsVisible="{Binding !IsLoading}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White"
                                CornerRadius="10"
                                Padding="20"
                                Margin="0,0,0,12"
                                BoxShadow="0 1 3 0 #1a000000">
                            <Grid ColumnDefinitions="Auto,*,Auto">

                                <!-- Date -->
                                <Border Grid.Column="0"
                                        Background="#edf2f7"
                                        CornerRadius="8"
                                        Padding="12"
                                        Width="70"
                                        Height="70"
                                        VerticalAlignment="Top">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Date, StringFormat='{}{0:dd}'}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#2d3748"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Date, StringFormat='{}{0:MMM}'}"
                                                   FontSize="12"
                                                   Foreground="#718096"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Informations -->
                                <StackPanel Grid.Column="1" Margin="20,0" Spacing="8">
                                    <TextBlock Text="{Binding Nom}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#2d3748"/>

                                    <TextBlock Text="{Binding Description}"
                                               FontSize="13"
                                               Foreground="#718096"
                                               TextWrapping="Wrap"
                                               MaxWidth="500"
                                               IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                    <StackPanel Orientation="Horizontal" Spacing="16">

                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="🕐" FontSize="14"/>
                                            <TextBlock Text="{Binding Horaire}"
                                                       FontSize="13"
                                                       Foreground="#4a5568"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="📍" FontSize="14"/>
                                            <TextBlock Text="{Binding Lieu}"
                                                       FontSize="13"
                                                       Foreground="#4a5568"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="👥" FontSize="14"/>
                                            <TextBlock Text="{Binding PlacesInfo}"
                                                       FontSize="13"
                                                       Foreground="#4a5568"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="💶" FontSize="14"/>
                                            <TextBlock Text="{Binding PrixDisplay}"
                                                       FontSize="13"
                                                       Foreground="#4a5568"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <Border Background="#e6fffa"
                                                CornerRadius="4"
                                                Padding="8,4">
                                            <TextBlock Text="{Binding TypePublicDisplay}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="#047857"/>
                                        </Border>

                                    </StackPanel>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

                                    <Button Command="{Binding $parent[ItemsControl].((vm:AteliersListViewModel)DataContext).ViewInscriptionsCommand}"
                                            CommandParameter="{Binding}"
                                            Background="#bee3f8"
                                            Foreground="#2c5282"
                                            Padding="12,8"
                                            CornerRadius="6"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <TextBlock Text="👥 Inscriptions" FontSize="13" FontWeight="SemiBold"/>
                                    </Button>

                                    <Button Command="{Binding $parent[ItemsControl].((vm:AteliersListViewModel)DataContext).EditAtelierCommand}"
                                            CommandParameter="{Binding}"
                                            Background="#fef5e7"
                                            Foreground="#d97706"
                                            Padding="10,8"
                                            CornerRadius="6"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <TextBlock Text="✏️" FontSize="14"/>
                                    </Button>

                                    <Button Command="{Binding $parent[ItemsControl].((vm:AteliersListViewModel)DataContext).DeleteAtelierCommand}"
                                            CommandParameter="{Binding}"
                                            Background="#fed7d7"
                                            Foreground="#c53030"
                                            Padding="10,8"
                                            CornerRadius="6"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <TextBlock Text="🗑️" FontSize="14"/>
                                    </Button>

                                </StackPanel>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Message si aucun atelier -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="40"
                    IsVisible="{Binding Ateliers.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}"
                    BoxShadow="0 1 3 0 #1a000000">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock Text="📅" FontSize="48" HorizontalAlignment="Center" Opacity="0.5"/>
                    <TextBlock Text="Aucun atelier disponible"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#4a5568"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Créez votre premier atelier pour commencer"
                               FontSize="13"
                               Foreground="#718096"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
