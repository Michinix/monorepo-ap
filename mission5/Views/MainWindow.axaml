<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:mission5.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="mission5.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="RAM Les Fripouilles - Gestion des Ateliers"
        Width="1200"
        Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#f7fafc">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="White"
                BorderBrush="#e2e8f0"
                BorderThickness="0,0,1,0">
            <StackPanel Spacing="8" Margin="0,24,0,0">

                <!-- Logo / Titre -->
                <StackPanel Spacing="8" Margin="24,0,24,24">
                    <Border Background="#edf2f7"
                            CornerRadius="50"
                            Width="60"
                            Height="60"
                            HorizontalAlignment="Center">
                        <TextBlock Text="🎨"
                                   FontSize="28"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Les Fripouilles"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="#2d3748"/>
                    <TextBlock Text="Gestion des Ateliers"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Foreground="#718096"/>
                </StackPanel>

                <!-- Menu Navigation -->
                <Border Background="#f7fafc"
                        CornerRadius="8"
                        Margin="12,0">
                    <Button Command="{Binding ShowAteliersCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="16,12"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="📅" FontSize="18"/>
                            <TextBlock Text="Ateliers"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#2d3748"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Gestion des paiements -->
                <Border Background="#f7fafc"
                        CornerRadius="8"
                        Margin="12,0">
                    <Button Command="{Binding ShowPaiementAdminCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="16,12"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="💳" FontSize="18"/>
                            <TextBlock Text="Paiements"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#2d3748"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Spacer -->
                <Border Height="1"/>

                <!-- Déconnexion -->
                <Border Margin="12,0">
                    <Button Command="{Binding LogoutCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="16,12"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="🚪" FontSize="18"/>
                            <TextBlock Text="Déconnexion"
                                       FontSize="14"
                                       Foreground="#e53e3e"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>

            </StackPanel>
        </Border>

        <!-- Contenu principal -->
        <Border Grid.Column="1" Padding="24">
            <ContentControl Content="{Binding CurrentPage}"/>
        </Border>

    </Grid>
</Window>
